---
// Panel /admin — SSR (lee la cookie, nunca se prerenderiza ni se indexa).
// Editor por PESTAÑAS: cada bloque editable es un <fieldset data-panel="X">
// de primer nivel; las pestañas solo muestran/ocultan por ese atributo.
// Solo se muestra lo que un cliente sin experiencia puede editar
// (SEO y el SVG del ícono quedan fuera / ocultos).
import "../../styles/global.css";
import { COOKIE, tokenValido } from "../../lib/auth";
import { contenido, IMAGENES } from "../../lib/contenido";

export const prerender = false;

// Claves de las fotos disponibles (para el <select> de domos/galería).
// En la Fase 4 (Cloudinary) esto se reemplaza por una subida real.
const CLAVES_IMG = Object.keys(IMAGENES);

const autenticado = tokenValido(Astro.cookies.get(COOKIE)?.value);
const errorLogin = Astro.url.searchParams.has("error");

// Indexado dinámico: contenido está tipado, aquí lo leemos por clave.
const C = contenido as Record<string, Record<string, string>>;

// Pestañas del panel (orden = orden de aparición). La 1ª es la visible al abrir.
const TABS = [
  { id: "portada", label: "Portada" },
  { id: "experiencia", label: "Experiencia" },
  { id: "domos", label: "Domos" },
  { id: "galeria", label: "Galería" },
  { id: "faq", label: "FAQ" },
  { id: "info", label: "Info y contacto" },
];
const INICIAL = TABS[0].id;

// campo: k=clave en data.json · label=nombre visible · multi=textarea · tab=pestaña
const HTML = "(admite HTML: <br /> salto de línea, <em>…</em> resalta en dorado)";
const SECCIONES = [
  { clave: "hero", tab: "portada", titulo: "Hero (portada)", campos: [
    { k: "eyebrow", label: "Etiqueta superior" },
    { k: "titulo", label: `Título ${HTML}`, multi: true },
    { k: "lede", label: "Subtítulo", multi: true },
    { k: "ctaPrimario", label: "Botón principal" },
    { k: "ctaSecundario", label: "Botón secundario" },
  ] },
  { clave: "cielo", tab: "portada", titulo: "Sección 'El cielo se apaga'", campos: [
    { k: "titulo", label: `Título ${HTML}`, multi: true },
    { k: "texto", label: "Párrafo", multi: true },
  ] },
  { clave: "experiencia", tab: "experiencia", titulo: "Experiencia (encabezado)", campos: [
    { k: "eyebrow", label: "Etiqueta superior" },
    { k: "titulo", label: "Título" },
  ] },
  { clave: "faq", tab: "faq", titulo: "Preguntas frecuentes (encabezado)", campos: [
    { k: "eyebrow", label: "Etiqueta superior" },
    { k: "titulo", label: "Título" },
  ] },
  { clave: "mapa", tab: "info", titulo: "Cómo llegar", campos: [
    { k: "eyebrow", label: "Etiqueta superior" },
    { k: "titulo", label: `Título ${HTML}`, multi: true },
    { k: "texto", label: "Texto (usa {ubicacion} donde va la ciudad)", multi: true },
    { k: "cta", label: "Botón" },
  ] },
  { clave: "reserva", tab: "info", titulo: "Reserva (formulario)", campos: [
    { k: "eyebrow", label: "Etiqueta superior" },
    { k: "titulo", label: "Título" },
    { k: "texto", label: "Párrafo", multi: true },
  ] },
  { clave: "cta", tab: "info", titulo: "Llamado final", campos: [
    { k: "titulo", label: `Título ${HTML}`, multi: true },
    { k: "texto", label: "Párrafo", multi: true },
    { k: "label", label: "Botón" },
  ] },
  { clave: "footer", tab: "info", titulo: "Pie de página", campos: [
    { k: "tagline", label: "Frase de marca", multi: true },
    { k: "reservaTexto", label: "Texto de la columna Reserva" },
    { k: "reservaLabel", label: "Botón de reserva" },
  ] },
  { clave: "nav", tab: "info", titulo: "Navegación", campos: [
    { k: "marca", label: "Nombre de marca" },
    { k: "ctaReserva", label: "Botón de reserva" },
  ] },
];

const inputCls = "rounded-xl border border-linea bg-transparent px-4 py-2.5 text-hueso focus-visible:border-dorado-suave focus-visible:outline-none";
const filaCls = "fila flex flex-col gap-2 rounded-xl border border-linea p-4";
const fieldCls = "flex flex-col gap-4 rounded-2xl border border-linea p-6";
const legendCls = "px-2 font-display text-xl text-dorado-suave";
const quitarCls = "quitar self-end text-sm text-tenue transition hover:text-dorado-suave";
const agregarCls = "self-start rounded-full border border-linea px-4 py-2 text-sm transition hover:border-dorado-suave hover:text-dorado-suave active:scale-95";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel · LUMBRE</title>
  </head>
  <body class="min-h-svh bg-noche-deep px-6 py-10 font-body text-hueso antialiased">
    {autenticado ? (
      <div class="mx-auto w-full max-w-2xl">
        <header class="flex items-center justify-between border-b border-linea pb-5">
          <h1 class="font-display text-3xl">Panel LUMBRE</h1>
          <form method="POST" action="/api/logout">
            <button type="submit" class="rounded-full border border-linea px-4 py-2 text-sm transition hover:border-dorado-suave hover:text-dorado-suave active:scale-95">
              Cerrar sesión
            </button>
          </form>
        </header>

        <div role="tablist" class="mt-8 flex flex-wrap gap-2">
          {TABS.map((t) => (
            <button type="button" role="tab" data-tab={t.id} aria-selected={t.id === INICIAL}
              class="tab rounded-full border border-linea px-4 py-2 text-sm text-tenue transition hover:text-hueso aria-selected:border-dorado-suave aria-selected:text-dorado-suave">
              {t.label}
            </button>
          ))}
        </div>

        <form id="editor" class="mt-6 flex flex-col gap-6">
          {SECCIONES.map((s) => (
            <fieldset data-panel={s.tab} hidden={s.tab !== INICIAL} class={fieldCls}>
              <legend class={legendCls}>{s.titulo}</legend>
              {s.campos.map((c) => (
                <label class="flex flex-col gap-2 text-sm">
                  {c.label}
                  {c.multi ? (
                    <textarea data-seccion={s.clave} data-campo={c.k} rows="2" class={inputCls}>{C[s.clave][c.k]}</textarea>
                  ) : (
                    <input data-seccion={s.clave} data-campo={c.k} value={C[s.clave][c.k]} class={inputCls} />
                  )}
                </label>
              ))}
            </fieldset>
          ))}

          <fieldset data-panel="experiencia" hidden={true} class={fieldCls}>
            <legend class={legendCls}>Razones (tarjetas)</legend>
            <div id="lista-features" class="flex flex-col gap-4">
              {contenido.experiencia.features.map((f) => (
                <div class={filaCls}>
                  <input data-campo="titulo" value={f.titulo} placeholder="Título" class={inputCls} />
                  <textarea data-campo="desc" rows="2" placeholder="Descripción" class={inputCls}>{f.desc}</textarea>
                  <input type="hidden" data-campo="icono" value={f.icono} />
                  <button type="button" class={quitarCls}>Quitar ✕</button>
                </div>
              ))}
            </div>
            <button type="button" data-agregar="lista-features" class={agregarCls}>+ Agregar razón</button>
          </fieldset>

          <fieldset data-panel="domos" hidden={true} class={fieldCls}>
            <legend class={legendCls}>Domos</legend>
            <div id="lista-domos" class="flex flex-col gap-4">
              {contenido.domos.map((d) => (
                <div class={filaCls}>
                  <input data-campo="nombre" value={d.nombre} placeholder="Nombre" class={inputCls} />
                  <select data-campo="img" class={inputCls}>
                    {CLAVES_IMG.map((k) => <option value={k} selected={k === d.img}>{k}</option>)}
                  </select>
                  <input data-campo="alt" value={d.alt} placeholder="Descripción de la foto" class={inputCls} />
                  <input data-campo="capacidad" value={d.capacidad} placeholder="Capacidad (ej. 2 personas)" class={inputCls} />
                  <input data-campo="precio" value={d.precio} placeholder="Precio (ej. 420.000)" class={inputCls} />
                  <textarea data-campo="detalles" rows="3" placeholder="Un detalle por línea" class={inputCls}>{d.detalles.join("\n")}</textarea>
                  <button type="button" class={quitarCls}>Quitar ✕</button>
                </div>
              ))}
            </div>
            <button type="button" data-agregar="lista-domos" class={agregarCls}>+ Agregar domo</button>
          </fieldset>

          <fieldset data-panel="galeria" hidden={true} class={fieldCls}>
            <legend class={legendCls}>Galería</legend>
            <div id="lista-galeria" class="flex flex-col gap-4">
              {contenido.galeria.map((g) => (
                <div class={filaCls}>
                  <select data-campo="img" class={inputCls}>
                    {CLAVES_IMG.map((k) => <option value={k} selected={k === g.img}>{k}</option>)}
                  </select>
                  <input data-campo="titulo" value={g.titulo} placeholder="Título" class={inputCls} />
                  <input data-campo="alt" value={g.alt} placeholder="Descripción de la foto" class={inputCls} />
                  <label class="flex items-center gap-2 text-sm text-tenue">
                    <input type="checkbox" data-campo="big" checked={g.big} /> Foto destacada (grande)
                  </label>
                  <button type="button" class={quitarCls}>Quitar ✕</button>
                </div>
              ))}
            </div>
            <button type="button" data-agregar="lista-galeria" class={agregarCls}>+ Agregar foto</button>
          </fieldset>

          <fieldset data-panel="faq" hidden={true} class={fieldCls}>
            <legend class={legendCls}>Preguntas (lista)</legend>
            <div id="lista-faq" class="flex flex-col gap-4">
              {contenido.faq.preguntas.map((p) => (
                <div class={filaCls}>
                  <input data-campo="q" value={p.q} placeholder="Pregunta" class={inputCls} />
                  <textarea data-campo="a" rows="2" placeholder="Respuesta" class={inputCls}>{p.a}</textarea>
                  <button type="button" class={quitarCls}>Quitar ✕</button>
                </div>
              ))}
            </div>
            <button type="button" data-agregar="lista-faq" class={agregarCls}>+ Agregar pregunta</button>
          </fieldset>

          <div class="sticky bottom-4 flex items-center gap-4 rounded-full border border-linea bg-noche-deep/90 px-6 py-3 backdrop-blur">
            <button type="submit" class="rounded-full bg-dorado px-8 py-3 text-sm font-semibold text-noche-deep transition duration-150 hover:shadow-[0_6px_26px_#e8a54b8c] active:scale-95">
              Guardar cambios
            </button>
            <p id="estado" role="status" class="text-sm text-tenue"></p>
          </div>
        </form>
      </div>

      <template id="tpl-lista-features">
        <div class={filaCls}>
          <input data-campo="titulo" placeholder="Título" class={inputCls} />
          <textarea data-campo="desc" rows="2" placeholder="Descripción" class={inputCls}></textarea>
          <input type="hidden" data-campo="icono" value="" />
          <button type="button" class={quitarCls}>Quitar ✕</button>
        </div>
      </template>
      <template id="tpl-lista-domos">
        <div class={filaCls}>
          <input data-campo="nombre" placeholder="Nombre" class={inputCls} />
          <select data-campo="img" class={inputCls}>
            {CLAVES_IMG.map((k) => <option value={k}>{k}</option>)}
          </select>
          <input data-campo="alt" placeholder="Descripción de la foto" class={inputCls} />
          <input data-campo="capacidad" placeholder="Capacidad (ej. 2 personas)" class={inputCls} />
          <input data-campo="precio" placeholder="Precio (ej. 420.000)" class={inputCls} />
          <textarea data-campo="detalles" rows="3" placeholder="Un detalle por línea" class={inputCls}></textarea>
          <button type="button" class={quitarCls}>Quitar ✕</button>
        </div>
      </template>
      <template id="tpl-lista-galeria">
        <div class={filaCls}>
          <select data-campo="img" class={inputCls}>
            {CLAVES_IMG.map((k) => <option value={k}>{k}</option>)}
          </select>
          <input data-campo="titulo" placeholder="Título" class={inputCls} />
          <input data-campo="alt" placeholder="Descripción de la foto" class={inputCls} />
          <label class="flex items-center gap-2 text-sm text-tenue">
            <input type="checkbox" data-campo="big" /> Foto destacada (grande)
          </label>
          <button type="button" class={quitarCls}>Quitar ✕</button>
        </div>
      </template>
      <template id="tpl-lista-faq">
        <div class={filaCls}>
          <input data-campo="q" placeholder="Pregunta" class={inputCls} />
          <textarea data-campo="a" rows="2" placeholder="Respuesta" class={inputCls}></textarea>
          <button type="button" class={quitarCls}>Quitar ✕</button>
        </div>
      </template>

      <script is:inline set:html={`window.__CONTENIDO__ = ${JSON.stringify(contenido)};`}></script>
      <script>
        const form = document.getElementById("editor");
        const estado = document.getElementById("estado");

        // Pestañas: muestra los paneles de la pestaña, oculta el resto.
        const tabs = document.querySelectorAll(".tab");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const id = (tab as HTMLElement).dataset.tab;
            tabs.forEach((t) => t.setAttribute("aria-selected", String(t === tab)));
            document.querySelectorAll("[data-panel]").forEach((p) => {
              (p as HTMLElement).hidden = (p as HTMLElement).dataset.panel !== id;
            });
          });
        });

        // Agregar fila: clona el molde <template id="tpl-<lista>">
        document.querySelectorAll("[data-agregar]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const listaId = (btn as HTMLElement).dataset.agregar!;
            const tpl = document.getElementById("tpl-" + listaId) as HTMLTemplateElement;
            document.getElementById(listaId)!.appendChild(tpl.content.cloneNode(true));
          });
        });
        // Quitar fila: delegación en el form (sirve para filas nuevas también)
        form?.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest(".quitar");
          if (btn) btn.closest(".fila")?.remove();
        });

        const val = (fila: Element, campo: string) =>
          (fila.querySelector(`[data-campo="${campo}"]`) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value.trim();
        const filas = (id: string) => [...document.querySelectorAll(`#${id} .fila`)];

        form?.addEventListener("submit", async (e) => {
          e.preventDefault();
          // Blindaje "mina": partir del contenido original (copia profunda) y
          // sobreescribir SOLO lo que el form recolecta. Nada se borra (ej. SEO).
          const original = (window as any).__CONTENIDO__;
          const datos = JSON.parse(JSON.stringify(original));
          form.querySelectorAll("[data-seccion]").forEach((el) => {
            const seccion = (el as HTMLElement).dataset.seccion!;
            const campo = (el as HTMLElement).dataset.campo!;
            datos[seccion][campo] = (el as HTMLInputElement | HTMLTextAreaElement).value;
          });

          // Listas: reconstruir el array leyendo las filas del DOM.
          datos.faq.preguntas = filas("lista-faq")
            .map((f) => ({ q: val(f, "q"), a: val(f, "a") }))
            .filter((p) => p.q || p.a);
          datos.experiencia.features = filas("lista-features")
            .map((f) => ({ titulo: val(f, "titulo"), desc: val(f, "desc"), icono: val(f, "icono") }))
            .filter((f) => f.titulo || f.desc);
          datos.domos = filas("lista-domos")
            .map((f) => ({
              nombre: val(f, "nombre"), img: val(f, "img"), alt: val(f, "alt"),
              capacidad: val(f, "capacidad"), precio: val(f, "precio"),
              detalles: (f.querySelector('[data-campo="detalles"]') as HTMLTextAreaElement).value
                .split("\n").map((s) => s.trim()).filter(Boolean),
            }))
            .filter((d) => d.nombre);
          datos.galeria = filas("lista-galeria")
            .map((f) => ({
              img: val(f, "img"), titulo: val(f, "titulo"), alt: val(f, "alt"),
              big: (f.querySelector('[data-campo="big"]') as HTMLInputElement).checked,
            }))
            .filter((g) => g.titulo || g.alt);

          estado!.textContent = "Guardando…";
          estado!.className = "text-sm text-tenue";
          try {
            const r = await fetch("/api/guardar", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(datos),
            });
            if (!r.ok) throw new Error(await r.text());
            (window as any).__CONTENIDO__ = datos;
            estado!.textContent = "✓ Guardado. En prod el sitio se actualiza en ~1 min.";
            estado!.className = "text-sm text-dorado-suave";
          } catch (err) {
            estado!.textContent = "✗ " + (err as Error).message;
            estado!.className = "text-sm text-dorado-suave";
          }
        });
      </script>
    ) : (
      <form method="POST" action="/api/login" class="w-full max-w-sm">
        <h1 class="font-display text-3xl">Panel LUMBRE</h1>
        <p class="mt-2 text-sm text-tenue">Entra para editar el contenido del sitio.</p>

        <label for="clave" class="mt-8 block text-sm">Contraseña</label>
        <input
          id="clave"
          name="clave"
          type="password"
          required
          autocomplete="current-password"
          class="mt-2 w-full rounded-xl border border-linea bg-transparent px-4 py-2.5 text-hueso transition focus-visible:border-dorado-suave focus-visible:outline-none"
        />

        {errorLogin && (
          <p role="alert" class="mt-3 text-sm text-dorado-suave">Contraseña incorrecta.</p>
        )}

        <button
          type="submit"
          class="mt-6 w-full rounded-full bg-dorado px-6 py-3 text-sm font-semibold text-noche-deep transition duration-150 hover:shadow-[0_6px_26px_#e8a54b8c] active:scale-95"
        >
          Entrar
        </button>
      </form>
    )}
  </body>
</html>
