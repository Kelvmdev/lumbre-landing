---
import { WHATSAPP } from "../lib/enlaces";
---

<section class="relative overflow-hidden py-28 text-center sm:py-36 lg:py-44">
  <div class="glow pointer-events-none absolute bottom-[20%] left-1/2 aspect-square w-[min(46rem,90vw)] -translate-x-1/2"></div>

  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <svg
      id="domo-cta"
      viewBox="0 0 400 200"
      aria-hidden="true"
      class="mx-auto mb-8 block w-[min(30rem,80vw)]"
    >
      <ellipse cx="200" cy="176" rx="150" ry="14" fill="#000" opacity="0.35"></ellipse>
      <path d="M60 176 A140 140 0 0 1 340 176 Z" fill="url(#domo-cta-grad)"></path>
      <g stroke="#e8a54b" stroke-width="1" opacity="0.45" fill="none">
        <path d="M60 176 A140 140 0 0 1 340 176"></path>
        <path d="M108 176 A92 92 0 0 1 292 176"></path>
        <path d="M60 176 L154 72 L246 72 L340 176 M154 72 L200 38 L246 72 M108 176 L200 116 L292 176 M200 38 L200 176"></path>
      </g>
      <rect x="178" y="134" width="44" height="42" rx="6" fill="#f0c88a"></rect>
      <defs>
        <radialGradient id="domo-cta-grad" cx="50%" cy="90%" r="90%">
          <stop offset="0%" stop-color="#f0c88a"></stop>
          <stop offset="55%" stop-color="#c98a4a"></stop>
          <stop offset="100%" stop-color="#1a1f38"></stop>
        </radialGradient>
      </defs>
    </svg>

    <h2 class="reveal font-display text-4xl leading-tight font-normal text-balance sm:text-5xl lg:text-6xl">
      La noche te está<br />esperando
    </h2>
    <p class="reveal mx-auto mt-5 max-w-md text-tenue">
      Solo hay tres domos. Elige tu fecha antes de que se apague la última luz.
    </p>
    <a
      href={WHATSAPP}
      target="_blank"
      rel="noopener"
      class="reveal mt-9 inline-block rounded-full bg-dorado px-8 py-3.5 text-sm font-semibold tracking-wide text-noche-deep shadow-[0_4px_18px_#e8a54b59] transition duration-150 hover:shadow-[0_6px_26px_#e8a54b8c] active:scale-95"
    >
      Reserva tu noche
    </a>
  </div>
</section>

<style>
  /* Resplandor radial dorado detrás del domo: degradado, no color plano
     (por eso no es un token/clase de Tailwind). */
  .glow {
    background: radial-gradient(circle, #e8a54b59, transparent 62%);
    filter: blur(6px);
    z-index: -1;
  }
</style>
