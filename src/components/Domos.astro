---
import { Image } from "astro:assets";
import domoAtardecer from "../assets/fotos/domo-atardecer.jpg";
import interiorDomo from "../assets/fotos/interior-domo.jpg";
import fogata from "../assets/fotos/fogata.jpg";
import { waReserva } from "../lib/enlaces";

// DEMO: 3 domos ficticios coherentes (glamping en Jardín, Antioquia).
// Precios en COP, rango realista de glamping en Colombia.
const domos = [
  {
    nombre: "Domo Estrella",
    img: domoAtardecer,
    alt: "Domo geodésico blanco sobre montaña verde al atardecer, con cielo dorado.",
    capacidad: "2 personas",
    precio: "420.000",
    detalles: ["Cama king frente al ventanal", "Baño privado con agua caliente", "Terraza con hamaca"],
  },
  {
    nombre: "Domo Luna",
    img: interiorDomo,
    alt: "Interior acogedor de un domo con cama, luces cálidas y estufa encendida.",
    capacidad: "2 personas",
    precio: "520.000",
    detalles: ["Tina de inmersión bajo el cielo", "Estufa de leña interior", "Desayuno de campo incluido"],
  },
  {
    nombre: "Domo Fuego",
    img: fogata,
    alt: "Fogata al aire libre junto a un domo en la hora azul del anochecer.",
    capacidad: "4 personas",
    precio: "680.000",
    detalles: ["Dos ambientes, ideal familias", "Fogón privado y asador", "Cena bajo las estrellas incluida"],
  },
];
---

<section id="domos" class="py-20 sm:py-28 lg:py-36">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="reveal mb-10 sm:mb-14">
      <p class="mb-2 text-xs tracking-[0.24em] text-dorado-suave uppercase">Los domos</p>
      <h2 class="font-display text-3xl font-normal sm:text-4xl lg:text-5xl">
        Tres refugios, una sola noche
      </h2>
      <p class="mt-4 max-w-xl text-tenue">
        Solo hay tres. Cada uno mira al bosque desde un ángulo distinto; elige el tuyo antes de que se agote la fecha.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
      {domos.map((d) => (
        <article class="reveal group flex flex-col overflow-hidden rounded-2xl border border-linea bg-[#2a2a4a47]">
          <div class="relative aspect-[4/3] overflow-hidden">
            <Image
              src={d.img}
              alt={d.alt}
              widths={[400, 800, 1200]}
              sizes="(min-width:768px) 33vw, 100vw"
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />
          </div>

          <div class="flex flex-1 flex-col p-6 sm:p-7">
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-display text-2xl font-normal text-hueso">{d.nombre}</h3>
              <span class="shrink-0 text-xs tracking-[0.12em] text-dorado-suave uppercase">{d.capacidad}</span>
            </div>

            <ul class="mt-4 space-y-1.5 text-sm text-tenue">
              {d.detalles.map((x) => (
                <li class="flex gap-2">
                  <span aria-hidden="true" class="mt-px text-dorado">·</span>
                  <span>{x}</span>
                </li>
              ))}
            </ul>

            <div class="mt-6 flex items-center justify-between gap-3 border-t border-linea pt-5">
              <p class="leading-tight text-hueso">
                <span class="block text-xs text-tenue">desde</span>
                <span class="font-display text-xl">${d.precio}</span>
                <span class="text-xs text-tenue"> COP · noche</span>
              </p>
              <a
                href={waReserva(d.nombre)}
                target="_blank"
                rel="noopener"
                class="shrink-0 rounded-full bg-dorado px-5 py-2.5 font-body text-sm font-semibold text-noche-deep shadow-[0_4px_18px_#e8a54b40] transition duration-150 hover:shadow-[0_6px_26px_#e8a54b73] active:scale-95"
              >
                Reservar
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
