---
// Un solo array alimenta DOS salidas: el acordeón visible y el schema FAQPage
// (GEO). Respuestas en texto plano para que sirvan igual en ambos.
import { contenido } from "../lib/contenido";

const faq = contenido.faq;
const faqs = faq.preguntas;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section id="faq" class="py-20 sm:py-28 lg:py-36">
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <div class="reveal mb-10 sm:mb-14">
      <p class="mb-2 text-xs tracking-[0.24em] text-dorado-suave uppercase">{faq.eyebrow}</p>
      <h2 class="font-display text-3xl font-normal sm:text-4xl lg:text-5xl">
        {faq.titulo}
      </h2>
    </div>

    <div class="reveal flex flex-col gap-3">
      {faqs.map((f) => (
        <details class="group rounded-2xl border border-linea bg-[#2a2a4a47] px-6 py-1">
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-display text-lg text-hueso marker:hidden sm:text-xl"
          >
            {f.q}
            <span
              aria-hidden="true"
              class="shrink-0 text-dorado transition-transform duration-200 group-open:rotate-45"
            >
              +
            </span>
          </summary>
          <p class="pb-5 font-body text-sm text-tenue sm:text-base">{f.a}</p>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
